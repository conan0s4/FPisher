@{
    ViewData["Title"] = "DashBoard";
}
<div>

    <h1>[DashBoard]</h1>

    <!-- Two Static Dashboard Boxes -->
    <div class="dashboard-totals">
        <!-- Total Clicks -->
        <div class="total-box">
            <h5>Total = Visit</h5>
            <h2>123</h2> <!-- example number -->
        </div>

        <!-- Total Logins -->
        <div class="total-box">
            <h5>Total = Login</h5>
            <h2>45</h2> <!-- example number -->
        </div>
    </div>

    <style>
        .dashboard-totals {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }

        .total-box {
            background-color: #111; /* dark background */
            color: white; /* green text */
            padding: 20px;
            border-radius: 8px;
            text-align: center;
            flex: 1; /* equal width boxes */
        }

            .total-box h5 {
                margin: 0 0 10px 0;
                font-size: 16px;
            }

            .total-box h2 {
                margin: 0;
                font-size: 32px;
                font-family: monospace;
            }

        /* Container to put tables side by side */
        .tables-container {
            display: flex;
            gap: 20px;
            align-items: flex-start;
        }

        .table-wrapper {
            flex: 1;
            min-width: 300px;
        }

        .scrollable-table {
            max-height: 300px;
            overflow-y: auto;
        }
    </style>

    <div class="tables-container">

        <!-- New Logins Table -->
        <div class="table-wrapper">
            <h3 style="color:#2cf876; font-family: monospace;">Compromised Users</h3>
            <form 
                  style="display: flex; gap: 6px; max-width: 400px; margin-bottom: 10px; justify-content: flex-start;">

                <input type="text" name="searchQuery" placeholder="Search..."
                       style="flex: 1; padding: 6px; border-radius: 4px; border: 1px solid #2cf876; background-color: #111; color: #2cf876;">

                <button type="submit"
                        style="padding: 6px 12px; background-color: black; border: 1px solid #2cf876; color: #2cf876; border-radius: 4px;">
                    ->
                </button>

            </form>

            <div class="scrollable-table">
                <table class="table table-dark table-striped" style="color:#2cf876; width:100%; border:1px solid #2cf876;">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>User</th>
                            <th>Password</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>01</td>
                            <td>lemongrab</td>
                            <td>password123</td>
                        </tr>
                        <!-- data coming soon -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Existing Clicks Table (unchanged) -->
        <div class="table-wrapper">
            <h3 style="color:#2cf876; font-family: monospace;">Link Visits</h3>

            <form
                  style="display: flex; gap: 6px; max-width: 400px; margin-bottom: 10px; justify-content: flex-start;">

                <input type="text" name="searchQuery" placeholder="Search..."
                       style="flex: 1; padding: 6px; border-radius: 4px; border: 1px solid #2cf876; background-color: #111; color:#2cf876;">

                <button type="submit"
                        style="padding: 6px 12px; background-color: black; border: 1px solid #2cf876; color:#2cf876; border-radius: 4px;">
                    ->
                </button>

            </form>

            <div class="scrollable-table">
                <table class="table table-dark table-striped" style="color:#2cf876; width:100%; border:1px solid #2cf876;">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Email</th>
                            <th>Campaign</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>01</td>
                            <td>lemongrab@gmail.com</td>
                            <td>meso-org</td>
                            <td>2025-11-20</td>
                        </tr>
                        <!-- data coming soon -->
                    </tbody>
                </table>
            </div>
        </div>

    </div>

</div>
