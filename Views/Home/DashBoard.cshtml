@{
    ViewData["Title"] = "DashBoard";
}
<div>
<div style="background-image: url('/images/fishhook.png');
            background-size: cover;
            background-repeat: no-repeat;
            background-position: center;
            min-height: 100vh;">
           <div> 
               <h1>[DashBoard]</h1>
           
            <!-- Two Static Dashboard Boxes -->
            <div class="dashboard-totals">
                <!-- Total Clicks -->
                <div class="total-box">
                    <h5>Total Clicks</h5>
                    <h2>123</h2> <!-- example number -->
                </div>

                <!-- Total Logins -->
                <div class="total-box">
                    <h5>Total Logins</h5>
                    <h2>45</h2> <!-- example number -->
                </div>
            </div>

            <style>
                .dashboard-totals {
                    display: flex;
                    gap: 20px;
                    margin-bottom: 20px;
                }

                .total-box {
                    background-color: #111; /* dark background */
                    color: white; /* green text */
                    padding: 20px;
                    border-radius: 8px;
                    text-align: center;
                    flex: 1; /* equal width boxes */
                }

                    .total-box h5 {
                        margin: 0 0 10px 0;
                        font-size: 16px;
                    }

                    .total-box h2 {
                        margin: 0;
                        font-size: 32px;
                        font-family: monospace;
                    }
            </style>
            <form asp-controller="Analytics" asp-action="Search" method="get"
                  style="display: flex; gap: 6px; max-width: 400px; margin-bottom: 10px; justify-content: flex-start;">

                <!-- Search Input -->
                <input type="text" name="searchQuery" placeholder="Search..."
                       style="flex: 1; padding: 6px; border-radius: 4px; border: 1px solid #0f0; background-color: #111; color: #0f0;">

                <!-- Submit Button -->
                <button type="submit"
                        style="padding: 6px 12px; background-color: black; border: 1px solid #2cf876; color: #0f0; border-radius: 4px;">
                    ->
                </button>

            </form>
   
            <div style="max-height:300px; overflow-y:auto;">
                <table class="table table-dark table-striped">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Email</th>
                            <th>Campaign</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>01</td>
                            <td>lemongrab@gmail.com</td>
                            <td>meso-org</td>
                            <td>2025-11-20</td>

                        </tr>
                        <!-- data coming soon -->
                    </tbody>
                </table>
            </div>

        </div>
</div>