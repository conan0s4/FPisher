@{
    ViewData["Title"] = "Campaign";
}

<div style="padding:20px; color:#2cf876; font-family: monospace; background-color:#000; min-height:100vh;">

    <h1 style="font-size:36px;">[Campaigns]</h1>

    <div style="display:flex; gap:20px; align-items:flex-start;">

        <!-- Left column -->
        <div style="flex:2;">
            <form asp-controller="Campaign" asp-action="SaveTemplate" method="post">
                <h1 style="font-size:20px;">Email Template</h1>
                <textarea name="emailTemplate" placeholder="Paste your email template here..."
                          style="width:100%; min-height:300px; background-color:#111; color:#2cf876; border:1px solid #2cf876; border-radius:4px; padding:10px;"></textarea>
                <button type="submit"
                        style="margin-top:10px; padding:6px 12px; background-color:black; border:1px solid #2cf876; color:#2cf876; border-radius:4px;">
                    Save Template
                </button>
            </form>

            <div style="margin-top:20px;">
                <button type="button"
                        style="padding:10px 20px; background-color:black; border:1px solid #2cf876; color:#2cf876; border-radius:4px;">
                    Import Landing Page
                </button>
            </div>
        </div>

        <!-- Right column -->
        <div style="flex:2;">

            <div style="margin-bottom:20px;">
                <form asp-controller="Campaign" asp-action="AddEmail" method="post" style="display:flex; gap:6px; max-width:600px;">
                    <input type="text" name="email" placeholder="Enter email..."
                           style="flex:1; padding:6px; border-radius:4px; border:1px solid #2cf876; background-color:#111; color:#2cf876;">

                    <select name="campaignId"
                            style="padding:6px; border-radius:4px; border:1px solid #2cf876; background-color:#111; color:#2cf876;">
                        <option value="1">Meso-Org Phish</option>
                        <option value="2">Test Campaign</option>
                    </select>

                    <button type="submit"
                            style="padding:6px 12px; background-color:black; border:1px solid #2cf876; color:#2cf876; border-radius:4px;">
                        Add
                    </button>
                </form>
            </div>

            <!-- Campaign selection + Attack button -->
            <div style="margin-bottom:10px; display:flex; gap:10px; align-items:center;">
                <label for="displayCampaign" style="margin-right:6px;">Select Campaign:</label>

                <select id="displayCampaign"
                        style="padding:6px; border-radius:4px; border:1px solid #2cf876; background-color:#111; color:#2cf876;">
                    <option value="1">Meso-Org Phish</option>
                    <option value="2">Test Campaign</option>
                </select>

                <button type="button"
                        style="padding:6px 16px; background-color:#111; border:1px solid #2cf876; color:#2cf876; border-radius:4px;">
                    Attack
                </button>
            </div>

            <div style="max-height:300px; overflow-y:auto;">
                <table class="table table-dark table-striped"
                       style="color:#2cf876; width:100%; border:1px solid #2cf876;">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Campaign Name</th>
                            <th>Emails</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>01</td>
                            <td>Meso-Org Phish</td>
                            <td>lemongrab@gmail.com</td>
                        </tr>
                    </tbody>
                </table>
            </div>

        </div>

    </div>

</div>
